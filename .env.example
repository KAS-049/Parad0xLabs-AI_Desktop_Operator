# Optional OpenAI key for live transcription, speech, image generation, and OpenAI-backed Codex flows.
# This environment variable is passed through to the backend child process.
OPENAI_API_KEY=

# Optional override for app root if you need to relocate the runtime.
CODEX_AVATAR_APP_ROOT=

# Optional override for app data and local state storage.
CODEX_AVATAR_USER_DATA=
