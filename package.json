{
  "name": "codex-avatar",
  "version": "0.1.0",
  "description": "Persistent voice-and-avatar front end for Codex.",
  "main": "dist/main/main.js",
  "author": "OpenAI Codex",
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "build:renderer": "vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build": "npm run build:renderer && npm run build:main",
    "start": "electron .",
    "package:win": "npm run build && electron-builder --win nsis"
  },
  "dependencies": {
    "@openai/codex": "^0.114.0",
    "@pixiv/three-vrm": "^3.4.2",
    "@types/pdfkit": "^0.17.5",
    "@types/ws": "^8.18.1",
    "docx": "^9.5.1",
    "pdfkit": "^0.18.0",
    "pngjs": "^7.0.0",
    "three": "^0.180.0",
    "uuid": "^11.1.0",
    "ws": "^8.19.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.3.0",
    "@types/pngjs": "^6.0.5",
    "electron": "^37.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.9.2",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "com.openclaw.codexavatar",
    "productName": "Codex Avatar",
    "files": [
      "dist/**/*",
      "characters/**/*",
      "docs/**/*",
      "README.md",
      "package.json"
    ],
    "directories": {
      "buildResources": "build"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
